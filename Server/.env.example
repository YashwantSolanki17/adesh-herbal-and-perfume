# Copy this file to .env and fill in your real values. Never commit .env to git.

# MongoDB connection string (from MongoDB Atlas, or your local MongoDB)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/aadeshHerbal

# Any long random string — used to sign login tokens
JWT_SECRET=change_this_to_a_long_random_secret_key

# From your Razorpay Dashboard > Settings > API Keys (use TEST keys first)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxx

PORT=5000
